{
  "name": "examples-v3",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "turbo run build:remix",
    "build:remix": "remix vite:build",
    "dev": "turbo run dev:remix",
    "dev:remix": "wait-on ./node_modules/@postenbring/hedwig-css/dist/index.css ./node_modules/@postenbring/hedwig-react/dist/index.js && remix vite:dev",
    "lint": "turbo run lint:eslint",
    "lint:eslint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "preview": "vite preview",
    "typecheck": "turbo run typecheck:tsc",
    "typecheck:tsc": "tsc --noEmit",
    "clean": "pnpm run clean:files && rm -rf node_modules",
    "clean:files": "rm -rf .turbo build"
  },
  "dependencies": {
    "@postenbring/hedwig-css": "3.0.6",
    "@postenbring/hedwig-react": "3.0.6",
    "@radix-ui/react-slot": "1.2.4",
    "@remix-run/node": "^2.17.2",
    "@remix-run/react": "^2.17.4",
    "isbot": "^5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "1.22.2"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "autoprefixer": "10.4.24",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.14",
    "turbo": "2.5.3",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "wait-on": "^8.0.3"
  },
  "packageManager": "pnpm@9.1.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "version": "3.0.6"
}
